---
import BaseHead from "~components/BaseHead.astro";
import { SITE_TITLE, SITE_DESCRIPTION } from "../../consts";
import { getCollection } from "astro:content";
import FormattedDate from "~components/FormattedDate.astro";
import BaseLayout from "~layouts/BaseLayout.astro";
import { Image } from "astro:assets";
import defaultHeroImage from "~images/blog-placeholder-1.jpg";

const posts = (await getCollection("blog")).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  </head>
  <BaseLayout>
    <div class="space-y-8">
      <h1 class="mb-8 text-3xl font-bold text-gray-900">Blog Posts</h1>
      <div class="grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-3">
        {
          posts.map((post) => (
            <a href={`/blog/${post.id}/`} class="block">
              <div class="flex h-full flex-col overflow-hidden rounded-lg bg-white shadow-md transition-shadow duration-300 hover:shadow-lg">
                <div>
                  <Image
                    src={post.data.heroImage ?? defaultHeroImage}
                    alt={post.data.title}
                    format="avif"
                    class="object-cover"
                  />
                </div>
                <div class="flex-grow p-4">
                  <h2 class="mb-2 line-clamp-2 text-lg font-semibold text-gray-900">
                    {post.data.title}
                  </h2>
                  <p class="text-sm text-gray-600">
                    <FormattedDate date={post.data.pubDate} />
                  </p>
                </div>
              </div>
            </a>
          ))
        }
      </div>
    </div>
  </BaseLayout>
</html>
