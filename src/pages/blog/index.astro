---
import BaseHead from "~components/BaseHead.astro";
import { SITE_TITLE, SITE_DESCRIPTION } from "../../consts";
import { getCollection } from "astro:content";
import FormattedDate from "~components/FormattedDate.astro";
import BaseLayout from "~layouts/BaseLayout.astro";
import { Image } from "astro:assets";
import defaultHeroImage from "~images/blog-placeholder-1.jpg";

const posts = (await getCollection("blog")).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  </head>
  <BaseLayout>
    <div class="space-y-8">
      <h1 class="text-3xl font-bold mb-8 text-gray-900">Blog Posts</h1>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {
          posts.map((post) => (
            <a href={`/blog/${post.id}/`} class="block">
              <div class="bg-white rounded-lg shadow-md overflow-hidden flex flex-col h-full hover:shadow-lg transition-shadow duration-300">
                <div>
                  <Image
                    src={post.data.heroImage ?? defaultHeroImage}
                    alt={post.data.title}
                    format="avif"
                    class="object-cover"
                  />
                </div>
                <div class="p-4 flex-grow">
                  <h2 class="text-lg font-semibold mb-2 line-clamp-2 text-gray-900">
                    {post.data.title}
                  </h2>
                  <p class="text-gray-600 text-sm">
                    <FormattedDate date={post.data.pubDate} />
                  </p>
                </div>
              </div>
            </a>
          ))
        }
      </div>
    </div>
  </BaseLayout>
</html>
