---
import { getCollection } from "astro:content";
import PostLink from "~/components/PostLink.astro";
import Layout from "~/layouts/Layout.astro";
import type { Meta } from "~/types";

const postsCollection = (await getCollection("posts")).sort(
  (front, back) => +back.data.updatedAt - +front.data.updatedAt,
);

const meta: Meta = {
  title: "전체 게시물 - Junseong Park",
  description:
    "이 페이지는 웹 애플리케이션을 빌드하고 배포하면서 얻은 지식과 경험을 기록한 모든 게시물을 모아둔 공간입니다.",
  path: "posts",
};
---

<Layout {...meta} >
  <section class="max-w-[600px] mx-auto">
    <h1 class="text-3xl font-extrabold border-b pb-6 mb-6" transition:name='post-list-heading'>전체 게시물</h1>
    <ul class="flex flex-col gap-1" transition:name="post-list">
      {
        postsCollection.map(post => (
          <li>
            <a href={`/posts/${post.slug}`} title={post.data.description}>
              <PostLink title={post.data.title} updatedAt={post.data.updatedAt} /> 
            </a>  
          </li>
        ))
      }
    </ul>
  </section>
</Layout>