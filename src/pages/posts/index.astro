---
import { getCollection } from "astro:content";
import Layout from "~/layouts/Layout.astro";

const allPosts = await getCollection("posts");
---

<Layout title="Posts - Junseong Park">
  <main>
    <h1 class="mb-4">Posts</h1>
    <ul class="space-y-2">
      {
        allPosts.map((post, index) => (
          <li class="bg-slate-800 hover:bg-slate-700 active:bg-slate-600 rounded-xl" transition:name={`item-${index}`}>
            <a class="flex justify-between p-4" href={`/posts/${post.slug}`} title={post.data.title}>
              <span>{post.data.title}</span>
              <span>&rarr;</span>
            </a>
          </li>
        ))
      }
    </ul>
  </main>
</Layout>
