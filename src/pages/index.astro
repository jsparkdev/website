---
import BaseHead from "../components/BaseHead.astro";
import { SITE_TITLE, SITE_DESCRIPTION } from "../consts";
import BaseLayout from "../layouts/BaseLayout.astro";
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  </head>
  <BaseLayout>
    <div class="max-w-2xl mx-auto">
      <h1 class="text-3xl font-bold mb-4">Welcome to My Personal Website</h1>
      <p class="mb-4">
        Hello! I'm a web developer passionate about creating beautiful and
        functional websites. This is my personal space where I share my thoughts
        and experiences through my blog.
      </p>
      <p>
        Feel free to explore my blog posts and get to know me better. If you
        have any questions or just want to chat, don't hesitate to reach out!
      </p>
    </div>
  </BaseLayout>
</html>
