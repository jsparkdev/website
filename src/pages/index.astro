---
import BaseHead from "~components/BaseHead.astro";
import { SITE_TITLE, SITE_DESCRIPTION } from "../consts";
import BaseLayout from "~layouts/BaseLayout.astro";

import TypeScriptIcon from "~stack/typescript.svg";
import ReactIcon from "~stack/react.svg";
import ViteIcon from "~stack/vite.svg";
import HonoIcon from "~stack/hono.svg";
import TailwindIcon from "~stack/tailwindcss.svg";
import RouterIcon from "~stack/reactrouter.svg";
import AstroIcon from "~stack/astro.svg";
import CloudflareIcon  from "~stack/cloudflare-workers.svg";

const techStack = [
  { name: "TypeScript", icon: TypeScriptIcon },
  { name: "React", icon: ReactIcon },
  { name: "Vite", icon: ViteIcon },
  { name: "Hono", icon: HonoIcon },
  { name: "Tailwind CSS", icon: TailwindIcon },
  { name: "React Router", icon: RouterIcon },
  { name: "Astro", icon: AstroIcon },
  { name: "Cloudflare Workers", icon: CloudflareIcon },
];
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  </head>
  <BaseLayout>
    <div class="space-y-12 text-center">
      <h1
        class="animate-gradient mb-6 bg-gradient-to-r from-indigo-600 to-pink-600 bg-clip-text text-4xl font-bold tracking-tight text-transparent sm:text-5xl md:text-6xl"
      >
        Welcome to My Digital Space
      </h1>
      <p
        class="mx-auto max-w-2xl text-lg leading-relaxed text-gray-600 sm:text-xl"
      >
        Hello! I'm a passionate web developer with a keen interest in frontend
        development. I love crafting beautiful, responsive, and user-friendly
        interfaces using modern web technologies.
      </p>
      <div class="space-y-4">
        <h2 class="text-2xl font-semibold text-gray-800 sm:text-3xl">
          Tech Stack I'm Excited About
        </h2>
        <div
          class="mx-auto grid max-w-3xl grid-cols-2 gap-6 sm:grid-cols-3 md:grid-cols-4"
        >
          {
            techStack.map((tech) => (
              <div class="flex flex-col items-center space-y-2 rounded-lg bg-white p-4 shadow-md transition-shadow duration-300 hover:shadow-lg">
                <tech.icon size={48} />
                <span class="text-sm font-medium text-gray-700">
                  {tech.name}
                </span>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </BaseLayout>
</html>
