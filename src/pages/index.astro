---
import Layout from "~/layouts/Layout.astro";
import TechStack from "~/components/TechStack.astro";
---

<Layout title="Junseong Park - Frontend Developer">
  <main class="space-y-8">
    <section>
      <h1 class="text-4xl font-extrabold text-slate-200 mb-1">Junseong Park</h1>
      <span>Frontend Developer</span>
    </section>
    <section class="space-y-2">
      <p>
        I build web applications using Vite and React ecosystem and deploy to
        Cloudflare Pages.
      </p>
      <p>
        I'm also interested in the latest open source web development
        technologies, React Native and Three.js.
      </p>
    </section>
    <section>
      <h2 class="text-2xl font-extrabold text-slate-200 mb-4">Tech Stack</h2>
      <TechStack />
    </section>
  </main>
</Layout>
