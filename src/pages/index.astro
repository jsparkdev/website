---
import BaseHead from "../components/BaseHead.astro";
import { SITE_TITLE, SITE_DESCRIPTION } from "../consts";
import BaseLayout from "../layouts/BaseLayout.astro";
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  </head>
  <BaseLayout>
    <div class="text-center">
      <h1
        class="font-poppins text-5xl font-bold tracking-tight sm:text-6xl md:text-7xl mb-6 bg-clip-text text-transparent bg-gradient-to-r from-indigo-600 to-pink-600 animate-gradient"
      >
        Welcome to My Digital Space
      </h1>
      <p class="mt-6 max-w-2xl mx-auto text-xl text-gray-600 leading-relaxed">
        Hello! I'm a passionate web developer crafting beautiful and functional
        digital experiences. Explore my thoughts, projects, and journey through
        web development.
      </p>
      <div class="mt-10 flex justify-center">
        <a
          href="/blog"
          class="px-8 py-3 rounded-full text-lg font-semibold text-white bg-gradient-to-r from-indigo-600 to-pink-600 hover:from-indigo-700 hover:to-pink-700 transition duration-300 ease-in-out transform hover:-translate-y-1 hover:shadow-lg"
        >
          Explore My Blog
        </a>
      </div>
    </div>
  </BaseLayout>
</html>
