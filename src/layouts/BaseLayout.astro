---
import "@fontsource-variable/jetbrains-mono";
import JetBrainsMonoWoff2 from "@fontsource-variable/jetbrains-mono/files/jetbrains-mono-latin-wght-normal.woff2?url";
import { SEO } from "astro-seo";

const {
  frontmatter: { title, description },
} = Astro.props;
---

<html lang="en">
  <head>
    <link rel="icon" href="/assets/icons/icon.svg" type="image/svg+xml" />
    <link rel="icon" href="/assets/icons/favicon.ico" sizes="32x32" />
    <link rel="apple-touch-icon" href="/assets/icons/apple-touch-icon.png" />
    <link rel="manifest" href="/manifest.webmanifest" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <link
      rel="preload"
      as="font"
      type="font/woff2"
      href={JetBrainsMonoWoff2}
      crossorigin="anonymous"
    />
    <SEO
      title={title}
      description={description}
      charset="utf-8"
      openGraph={{
        basic: {
          title,
          type: "website",
          image: `${Astro.url.href}assets/images/og-image.png`,
          url: Astro.url.href,
        },
        optional: {
          description,
          locale: "en_US",
          siteName: "Junseong Park",
        },
        image: {
          type: "image/png",
          width: 1200,
          height: 630,
        },
      }}
      twitter={{
        card: "summary_large_image",
        site: "@jsparkdev",
        creator: "@jsparkdev",
        title,
        description,
        image: `${Astro.url.href}assets/images/og-image.png`,
      }}
    />
  </head>
  <body>
    <main>
      <slot />
    </main>
  </body>
</html>

<style is:global>
  :root {
    --background-color: #e8f6f3;
    --text-color: #2c3e50;
    --link-color: #1abc9c;
    --accent-color: #16a085;
  }

  @media (prefers-color-scheme: dark) {
    :root {
      --background-color: #1a332e;
      --text-color: #e0f2f1;
      --link-color: #4ecca3;
      --accent-color: #45b7a0;
    }
  }

  body {
    background-color: var(--background-color);
    font-family: "JetBrains Mono Variable", monospace;
    cursor: default;
    user-select: none;
  }

  main {
    color: var(--text-color);
    max-width: 80ch;
    padding: 0.5em 0.75em;
    margin: 0 auto;
  }

  h1 {
    font-weight: 800;
    font-size: 2.5em;
  }

  h2 {
    font-weight: 800;
    font-size: 2em;
  }

  h3 {
    font-weight: 800;
    font-size: 1.5em;
  }

  p {
    text-wrap: balance;
  }

  ul {
    padding-inline-start: 1em;
  }

  a {
    color: var(--link-color);
    transition: color 0.3s ease;
    text-decoration: none;
  }

  a:hover,
  a:focus {
    color: var(--accent-color);
    text-decoration: underline;
  }

  @media (max-width: 400px) {
    h1 {
      font-size: 2em;
    }
    h2 {
      font-size: 1.5em;
    }
    h3 {
      font-size: 1em;
    }
  }
</style>
