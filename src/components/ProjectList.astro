---
import { getCollection } from "astro:content";
import Card from "./Card.astro";

interface Props {
	preview?: boolean;
}

const { preview } = Astro.props;

const allProjects = (await getCollection("projects")).slice(
	0,
	preview ? 2 : undefined,
);
---

<ul class="space-y-2">
  {
    allProjects.map((project) => (
      <li transition:name={`project-item-${project.id}`}>
        <Card hover>
          <a href={project.data.url} class="flex flex-col p-4" title={`Link to ${project.data.title}`}>
            <h2 class="text-2xl">{project.data.title}</h2>
            <p>{project.data.description}</p>
          </a>
        </Card>
      </li>
    ))
  }
</ul>