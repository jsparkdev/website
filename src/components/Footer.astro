---
import Github from "~icons/social/github.svg";
import Linkedin from "~icons/social/linkedin.svg";
import Twitter from "~icons/social/twitter.svg";

const today = new Date();
---

<footer class="py-6 md:py-8">
  <div class="container mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
    <div class="flex flex-col items-center space-y-4">
      <div class="flex space-x-4">
        <a
          href="https://github.com/jsparkdev"
          target="_blank"
          rel="noopener noreferrer"
          class="text-gray-600 hover:text-gray-900"
        >
          <Github size={20} />
          <span class="sr-only">GitHub</span>
        </a>
        <a
          href="https://linkedin.com/in/jsparkdev"
          target="_blank"
          rel="noopener noreferrer"
          class="text-gray-600 hover:text-gray-900"
        >
          <Linkedin size={20} />
          <span class="sr-only">Linkedin</span>
        </a>
        <a
          href="https://x.com/jsparkdev"
          target="_blank"
          rel="noopener noreferrer"
          class="text-gray-600 hover:text-gray-900"
        >
          <Twitter size={20} />
          <span class="sr-only">Twitter</span>
        </a>
      </div>
      <p class="text-center text-sm text-gray-600">
        &copy; {today.getFullYear()} Junseong Park. All rights reserved.
      </p>
      <p class="text-center text-xs text-gray-500">
        Created with{" "}
        <a
          href="https://astro.build"
          target="_blank"
          rel="noopener noreferrer"
          class="underline hover:text-gray-700"
        >
          Astro
        </a>{" "}
        and{" "}
        <a
          href="https://v0.dev"
          target="_blank"
          rel="noopener noreferrer"
          class="underline hover:text-gray-700"
        >
          v0
        </a>
      </p>
    </div>
  </div>
</footer>
