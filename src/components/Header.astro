---
import Default from '@astrojs/starlight/components/Header.astro'
import type { Props } from '@astrojs/starlight/props'
---

<Default {...Astro.props}><slot /></Default>
<div class="scroll-watcher min-h-1 w-full z-50 fixed origin-left landscape:hidden" />

<style>
  .scroll-watcher {
    scale: 0 1;
    animation: scroll linear;
    animation-timeline: scroll(y);
    background: rgb(2,0,36);
    background: linear-gradient(90deg, rgba(255,0,0,1) 0%, rgba(255,158,6,1) 20%, rgba(224,255,18,1) 40%, rgba(0,255,6,1) 60%, rgba(26,29,255,1) 80%, rgba(194,0,255,1) 100%);
  }

  @keyframes scroll {
    to {
      scale: 1;
    }
  }
</style>
