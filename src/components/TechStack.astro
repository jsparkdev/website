---
import { Icon } from "astro-icon/components";

const techStack = [
  {
    name: "React",
    icon: "skill-icons:react-dark",
  },
  {
    name: "Vite",
    icon: "skill-icons:vite-dark",
  },
  {
    name: "TypeScript",
    icon: "skill-icons:typescript",
  },
  {
    name: "Remix",
    icon: "skill-icons:remix-dark",
  },
  {
    name: "Astro",
    icon: "skill-icons:astro",
  },
  {
    name: "Tailwind CSS",
    icon: "skill-icons:tailwindcss-dark",
  },
  {
    name: "Cloudflare Pages",
    icon: "skill-icons:cloudflare-light",
  },
  {
    name: "Vercel",
    icon: "skill-icons:vercel-light",
  },
];
---

<ul class="grid grid-cols-2 gap-4 portrait:grid-cols-1">
  {
    techStack.map((stack) => (
      <li>
        <div class="flex items-center gap-3 bg-slate-800 p-4 rounded-xl">
          <Icon name={stack.icon} size={48} />
          <span>{stack.name}</span>
        </div>
      </li>
    ))
  }
</ul>
