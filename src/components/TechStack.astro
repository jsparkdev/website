---
import { Icon } from "astro-icon/components";
import Card from "./Card.astro";

const techStack = [
	{
		name: "React",
		icon: "skill-icons:react-dark",
	},
	{
		name: "Vite",
		icon: "skill-icons:vite-dark",
	},
	{
		name: "TypeScript",
		icon: "skill-icons:typescript",
	},
	{
		name: "Remix",
		icon: "skill-icons:remix-light",
	},
	{
		name: "Astro",
		icon: "skill-icons:astro",
	},
	{
		name: "Tailwind CSS",
		icon: "skill-icons:tailwindcss-light",
	},
];
---

<ul class="grid grid-cols-2 gap-4 portrait:grid-cols-1">
  {
    techStack.map((stack) => (
      <li>
				<Card>
					<div class="flex items-center gap-3 p-4">
						<Icon name={stack.icon} size={48} />
						<span>{stack.name}</span>
					</div>
				</Card>
      </li>
    ))
  }
</ul>
