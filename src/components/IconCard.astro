---
import { Icon } from 'astro-icon/components'

interface Props {
	icon: string
	name: string
	href?: string
}

export type IconCardProps = Props

const { icon, name, href } = Astro.props
const size = 30
---

<a class="antialiased flex items-center gap-3 dark:bg-slate-500 hover:bg-slate-400 duration-500 py-3 px-5 rounded-xl mt-4 group" href={href} title={name} target="_blank">
  <div class="group-hover:rotate-[10deg] duration-500">
    <Icon name={icon} size={size} />
  </div>
  <span class="text-white group-hover:text-slate-700 duration-500">{name}</span>
</a>
