{
  "extends": "astro/tsconfigs/strict",
  "include": [".astro/types.d.ts", "**/*"],
  "exclude": ["dist"],
  "compilerOptions": {
    "strictNullChecks": true,
    "baseUrl": ".",
    "paths": {
      "~/*": ["src/*"],
      "~icons/*": ["src/assets/icons/*"],
      "~images/*": ["src/assets/images/*"]
    }
  }
}
