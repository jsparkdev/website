{
	"$schema": "https://biomejs.dev/schemas/1.8.0/schema.json",
	"files": {
		"include": ["**/*.mjs", "**/*.json", "src/**/*"],
		"ignore": ["node_modules"]
	},
	"javascript": {
		"formatter": {
			"quoteStyle": "single",
			"jsxQuoteStyle": "single",
			"semicolons": "asNeeded",
			"arrowParentheses": "asNeeded"
		}
	}
}
